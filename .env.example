# Database
DATABASE_URL="postgresql://..."

# Auth
AUTH_SECRET="your_auth_secret"

# UploadThing
UPLOADTHING_TOKEN="your_uploadthing_token"

# Telegram order notifications (server-only; optional — if unset, notifications are skipped)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Explicit admin bootstrap. Required only when running npm run seed.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace_with_a_strong_password"
SEED_ADMIN_NAME="Admin"
